<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Ginansya" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/light_primary</item>
        <item name="colorOnPrimary">@color/light_on_primary</item>
        <item name="colorPrimaryContainer">@color/light_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/light_on_primary_container</item>
        <item name="colorSecondary">@color/light_secondary</item>
        <item name="colorOnSecondary">@color/light_on_secondary</item>
        <item name="colorSecondaryContainer">@color/light_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/light_on_secondary_container</item>
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorOnBackground">@color/light_on_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_on_surface</item>
        <item name="colorSurfaceVariant">@color/light_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/light_on_surface_variant</item>
        <item name="colorOutline">@color/light_outline</item>
        <item name="colorOutlineVariant">@color/light_outline_variant</item>
        <item name="colorError">@color/light_error</item>
        <item name="colorOnError">@color/light_on_error</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">?colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Ginansya.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Ginansya.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Ginansya.Large</item>
    </style>

    <style name="Theme.Ginansya" parent="Base.Theme.Ginansya" />

    <style name="ShapeAppearance.Ginansya.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeAppearance.Ginansya.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeAppearance.Ginansya.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="TextAppearance.Ginansya.HeroAmount" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:textColor">?colorOnPrimary</item>
    </style>

    <style name="TextAppearance.Ginansya.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.Ginansya.CardTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Ginansya.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.Ginansya.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?colorSurface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?colorOutlineVariant</item>
    </style>

    <style name="Widget.Ginansya.Card.Hero" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?colorPrimary</item>
    </style>

    <style name="Widget.Ginansya.Card.QuickAction" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?colorPrimaryContainer</item>
        <item name="rippleColor">?colorPrimary</item>
    </style>

    <style name="Widget.Ginansya.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">?colorSurface</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Ginansya.BottomNav.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.Ginansya.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?colorPrimaryContainer</item>
    </style>
</resources>
